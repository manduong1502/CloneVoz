generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// GLOBAL SETTINGS
// ----------------------------------------------------------------------------
model GlobalSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// ----------------------------------------------------------------------------
// USERS & GROUPS
// ----------------------------------------------------------------------------
model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  emailVerified DateTime?
  passwordHash  String?
  avatar        String?
  customTitle   String?
  signature     String?
  
  // Stats
  messageCount  Int      @default(0)
  reactionScore Int      @default(0)
  points        Int      @default(0)

  // Status
  isBanned      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relationships
  userGroups        UserGroup[] @relation("UserToGroup")
  threads           Thread[]
  posts             Post[]
  reactions         Reaction[]
  
  // Phase 2 Relationships
  notifications     Notification[] @relation("UserNotifications")
  sentNotifications Notification[] @relation("NotificationSender")
  bookmarks         Bookmark[]
  conversations     Conversation[] @relation("ConversationParticipants")
  messages          ConversationMessage[]
  shouts            ShoutboxMessage[] @relation("UserShouts")
  shoutReactions    ShoutboxReaction[] @relation("UserShoutReactions")

  accounts          Account[]
  sessions          Session[]

  // Phase 3 Relationships
  reportsFiled      Report[]  @relation("UserReports")
  reportsAssigned   Report[]  @relation("ModAssignedReports")
  warningsReceived  Warning[] @relation("UserWarnings")
  warningsIssued    Warning[] @relation("ModIssuedWarnings")
}

model UserGroup {
  id          String  @id @default(cuid())
  name        String  @unique // e.g. "Admin", "Moderator", "Registered"
  styling     String? // CSS class or color for username
  priority    Int     @default(10) // 1000 for Admin, 10 for basic...
  
  // Privileges (simplified)
  canBan      Boolean @default(false)
  canDelete   Boolean @default(false)
  canEditAny  Boolean @default(false)
  canApprove  Boolean @default(false) // Quyền duyệt bài viết mới

  // Relationships
  users       User[]  @relation("UserToGroup")
}

// ----------------------------------------------------------------------------
// NODES (Categories & Forums)
// ----------------------------------------------------------------------------
model Node {
  id          String   @id @default(cuid())
  title       String
  description String?
  nodeType    String   @default("Forum") // "Category", "Forum", "Link"
  
  // Nested Set & Ordering
  parentId    String?
  parent      Node?    @relation("NodeHierarchy", fields: [parentId], references: [id])
  children    Node[]   @relation("NodeHierarchy")
  displayOrder Int     @default(10)
  
  // Stats cache
  threadsCount Int     @default(0)
  postsCount   Int     @default(0)
  lastPostId   String? 
  
  // Phase 3 Permissions (Anti-Spam / Restricted Box)
  minAccountAgeDays Int @default(0) // Số ngày tuổi tối thiểu của nick (VD: f33 cần 60 ngày)
  minMessageCount   Int @default(0) // Số comment tối thiểu để được vào (VD: f33 cần 15 comment)

  // Relationships
  threads     Thread[]
  prefixes    ThreadPrefix[] @relation("NodeToPrefix")
  bookmarks   Bookmark[]
}

// ----------------------------------------------------------------------------
// THREADS & POSTS
// ----------------------------------------------------------------------------
model ThreadPrefix {
  id      String  @id @default(cuid())
  title   String  // e.g. "Chú ý", "Tin tức"
  cssClass String // e.g. "voz-badge-warning"
  
  threads Thread[]
  nodes   Node[]  @relation("NodeToPrefix")
}

model Thread {
  id          String    @id @default(cuid())
  title       String
  isLocked    Boolean   @default(false)
  isPinned    Boolean   @default(false)
  isApproved  Boolean   @default(false) // Duyệt bài: false = chờ duyệt
  
  viewCount   Int       @default(0)
  replyCount  Int       @default(0)

  nodeId      String
  node        Node      @relation(fields: [nodeId], references: [id])
  
  prefixId    String?
  prefix      ThreadPrefix? @relation(fields: [prefixId], references: [id])

  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Fast read references (Denormalization optimization)
  firstPostId String?   
  lastPostId  String?   

  posts       Post[]
  bookmarks   Bookmark[]
  reports     Report[]
}

model Post {
  id        String   @id @default(cuid())
  content   String   // HTML from Rich Text Editor
  position  Int      // 1 for first post, 2 for first reply...
  
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reactions Reaction[]
  reports   Report[]
}

// ----------------------------------------------------------------------------
// REACTIONS
// ----------------------------------------------------------------------------
model Reaction {
  id        String   @id @default(cuid())
  type      String   // "Like", "Haha", "Angry", "Sad", "Love"
  
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([postId, userId]) // 1 user can only have 1 reaction per post
}

// ----------------------------------------------------------------------------
// PHASE 2: NOTIFICATIONS & INTERACTIONS
// ----------------------------------------------------------------------------

model Notification {
  id        String   @id @default(cuid())
  type      String   // "quote", "reaction", "mention", "reply"
  content   String   // Chứa text ngắn gọn gọn, hoặc JSON data
  isRead    Boolean  @default(false)
  link      String?  // Link tới bài viết/thread
  
  userId    String   // Người NHẬN thông báo
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  
  senderId  String?  // Người GÂY RA thông báo (tùy chọn)
  sender    User?    @relation("NotificationSender", fields: [senderId], references: [id])

  createdAt DateTime @default(now())
}

model Bookmark {
  id        String   @id @default(cuid())
  label     String?  // Ghi chú khi lưu
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  threadId  String?
  thread    Thread?  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  
  nodeId    String?
  node      Node?    @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Conversation {
  id          String   @id @default(cuid())
  title       String
  isLocked    Boolean  @default(false)
  
  // Những người tham gia đoạn chat
  participants User[]  @relation("ConversationParticipants")
  
  messages    ConversationMessage[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastMessageId String?
}

model ConversationMessage {
  id             String       @id @default(cuid())
  content        String
  
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  authorId       String
  author         User         @relation(fields: [authorId], references: [id])

  createdAt      DateTime     @default(now())
}

model ShoutboxMessage {
  id        String   @id @default(cuid())
  content   String
  
  authorId  String
  author    User     @relation("UserShouts", fields: [authorId], references: [id])

  reports   Report[] @relation("ReportedShouts")
  reactions ShoutboxReaction[] @relation("ShoutReactions")

  createdAt DateTime @default(now())
}

model ShoutboxReaction {
  id                String          @id @default(cuid())
  type              String          // "Like", "Haha", "Love", "Sad", "Angry"
  
  shoutboxMessageId String
  shoutboxMessage   ShoutboxMessage @relation("ShoutReactions", fields: [shoutboxMessageId], references: [id], onDelete: Cascade)
  
  userId            String
  user              User            @relation("UserShoutReactions", fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime        @default(now())

  @@unique([shoutboxMessageId, userId]) // 1 user = 1 reaction per shout
}

// ----------------------------------------------------------------------------
// PHASE 3: REPORTS & WARNINGS
// ----------------------------------------------------------------------------

model Report {
  id          String   @id @default(cuid())
  reason      String   // Nội dung báo cáo (Spam, Xúc phạm, Ngôn từ đả kích...)
  status      String   @default("pending") // pending, resolved, rejected
  
  reporterId  String
  reporter    User     @relation("UserReports", fields: [reporterId], references: [id])
  
  // Đối tượng bị report (Thread, Post, hoặc ShoutboxMessage)
  postId      String?
  post        Post?            @relation(fields: [postId], references: [id], onDelete: Cascade)
  threadId    String?
  thread      Thread?          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  shoutboxMessageId String?
  shoutboxMessage   ShoutboxMessage? @relation("ReportedShouts", fields: [shoutboxMessageId], references: [id], onDelete: Cascade)

  assignedToId String? // Admin/Mod nào đang xử lý
  assignedTo   User?   @relation("ModAssignedReports", fields: [assignedToId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Warning {
  id          String   @id @default(cuid())
  reason      String   // Lý do phạt
  points      Int      // Số điểm phạt phụ thuộc mức độ nghiêm trọng
  expiresAt   DateTime? // Thẻ phạt hết hạn (hoặc null nếu vĩnh viễn)
  
  userId      String   // Người bị phạt
  user        User     @relation("UserWarnings", fields: [userId], references: [id], onDelete: Cascade)

  issuerId    String   // Admin/Mod ra quyết định
  issuer      User     @relation("ModIssuedWarnings", fields: [issuerId], references: [id])

  createdAt   DateTime @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

