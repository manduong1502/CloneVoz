# Mẫu file .env để copy lên VPS Ubuntu
# Copy ném thẳng vào file /voz/.env trên VPS

# KHÔNG DÙNG FILE CỦA SQLITE NỮA! CHÚNG TA ĐANG DÙNG POSTGRESQL!
# Default theo file vps-setup.sh thì nó là cái này, anh không cần sửa dòng này:
DATABASE_URL="postgresql://voz_user:VozAdmin@@2026@localhost:5432/voz_db?schema=public"

# THÔNG TIN GOOGLE (Bốc 3 mã cũ từ file .env ở máy anh dán sang đây)
AUTH_SECRET="DanOngThongMinh_Sieu_Bao_Mat_2026_Key"
AUTH_GOOGLE_ID="[DÁN LẠI AUTH GOOGLE ID MỚI Ở ĐÂY HOẶC CŨ CŨNG ĐƯỢC]"
AUTH_GOOGLE_SECRET="[DÁN LẠI AUTH GOOGLE SECRET MỚI Ở ĐÂY HOẶC CŨ CŨNG ĐƯỢC]"

# CLOUDINARY UPLOAD CONFIGURATION
CLOUDINARY_CLOUD_NAME="[Dán vào]"
CLOUDINARY_API_KEY="[Dán vào]"
CLOUDINARY_API_SECRET="[Dán vào]"

# PUSHER CONFIGURATION
PUSHER_APP_ID="[Dán vào]"
NEXT_PUBLIC_PUSHER_KEY="[Dán vào]"
PUSHER_SECRET="[Dán vào]"
NEXT_PUBLIC_PUSHER_CLUSTER="ap1"

# REDIS CACHING
REDIS_URL="redis://localhost:6379"
